# Node backend
PORT=3001
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# ── Supabase PostgreSQL ──────────────────────────────────────────────────────
# Paste your connection string from:
#   Supabase Dashboard → Project Settings → Database → Connection string
#
# Use Transaction mode (port 6543) for most cases:
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true
#
# Use Session mode (port 5432) if you need prepared statements / LISTEN-NOTIFY:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── ML inference service ─────────────────────────────────────────────────────
ML_API_URL=http://localhost:8001
ML_TIMEOUT_MS=5000
